<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.msa4meerkatgram.domain.auth.mapper.AuthMapper">


    <!-- 특정 사용자의 refresh_token 값을 새 토큰으로 업데이트하는 SQL -->
    <update
            id="updateRefreshToken"
            parameterType="com.msa4meerkatgram.domain.user.entities.User"
    >
        UPDATE users
        SET
            refresh_token = #{refreshToken}
            ,updated_at = NOW()
        WHERE
            id = #{id}
    </update>

    <insert
            id="create"
            parameterType="com.msa4meerkatgram.domain.user.entities.User"
            useGeneratedKeys="true"
            keyProperty="id"
    >
        INSERT INTO users(
             email
            ,password
            ,nick
            ,role
            ,provider
            ,profile
        ) VALUES (
             #{email}
            ,#{password}
            ,#{nick}
            ,#{role}
            ,#{provider}
            ,#{profile}
        )

    </insert>
</mapper>